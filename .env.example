PORT=3001
SESSION_SECRET=replace-with-a-long-random-string

# Google OAuth (required for Calendar + Drive backup features)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

CLIENT_URL=http://localhost:3001
NODE_ENV=development

# Comma-separated list of IPs allowed to access the dashboard
ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# Optional: a specific Google Calendar to read/write (defaults to your primary calendar)
DASHBOARD_CALENDAR_ID=

# Groq API key — powers AI meal/calendar text parsing (free tier at https://console.groq.com)
GROQ_API_KEY=

# Gemini API key — powers the chat assistant and scheduled summaries (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
